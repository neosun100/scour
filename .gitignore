# Local configuration — contains your gateway URL / profile, never commit.
# Patterns are unanchored, so they also match the runtime bundle in
# skills/scour/ (.env, .venv there are ignored too).
.env

# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
.claude/

# Python packaging artifacts
build/
dist/
