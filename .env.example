# Copy to .env and fill in. The .env file is gitignored.

# Required: the AgentCore Gateway MCP endpoint (printed by ./setup.sh)
AGENTCORE_GATEWAY_URL=https://<gateway-id>.gateway.bedrock-agentcore.us-east-1.amazonaws.com/mcp

# Optional: AWS profile to use. If unset, the default credential chain is used
# (environment variables, ~/.aws/credentials, SSO, instance role, etc.).
# AWS_PROFILE=your-profile

# Optional (MCP server `scour-mcp --http` only): bind host/port.
# MCP_HOST=127.0.0.1
# MCP_PORT=8000
